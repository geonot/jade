{
  "grammars": [
    {
      "name": "jinn",
      "camelcase": "Jinn",
      "scope": "source.jn",
      "path": ".",
      "file-types": ["jinn"],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^jinn$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Jinn programming language",
    "authors": [{ "name": "Jinn Contributors" }]
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
