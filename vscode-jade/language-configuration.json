{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(\\*\\w|if\\b|elif\\b|else\\b|while\\b|until\\b|unless\\b|for\\b|match\\b|type\\b|enum\\b|trait\\b|impl\\b|actor\\b|store\\b|loop\\b|do\\b).*$",
    "decreaseIndentPattern": "^\\s*(else|elif|end)\\b"
  },
  "folding": {
    "offSide": true,
    "markers": {
      "start": "^\\s*#\\s*region\\b",
      "end": "^\\s*#\\s*endregion\\b"
    }
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "onEnterRules": [
    {
      "beforeText": "^\\s*(\\*\\w+\\(.*\\)|if\\b.*|elif\\b.*|else|while\\b.*|until\\b.*|unless\\b.*|for\\b.*|match\\b.*|type\\b.*|enum\\b.*|trait\\b.*|impl\\b.*|actor\\b.*|store\\b.*|loop|do)\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}
