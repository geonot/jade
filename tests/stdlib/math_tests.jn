use std/math

test 'constants'
    assert math.PI > 3.14
    assert math.PI < 3.15
    assert math.E > 2.71
    assert math.E < 2.72
    assert math.TAU > 6.28

test 'abs'
    assert math.abs(-5) equals 5
    assert math.abs(5) equals 5
    assert math.abs(0) equals 0

test 'sign'
    assert math.sign(-7) equals -1
    assert math.sign(0) equals 0
    assert math.sign(42) equals 1

test 'clamp'
    assert math.clamp(5, 0, 10) equals 5
    assert math.clamp(-3, 0, 10) equals 0
    assert math.clamp(99, 0, 10) equals 10

test 'lerp midpoint'
    v is math.lerp(0.0, 10.0, 0.5)
    assert v > 4.99
    assert v < 5.01

test 'degrees / radians round-trip'
    d is math.degrees(math.PI)
    assert d > 179.9
    assert d < 180.1
    r is math.radians(180.0)
    assert r > 3.14
    assert r < 3.15

test 'hypot 3-4-5'
    h is math.hypot(3.0, 4.0)
    assert h > 4.99
    assert h < 5.01

test 'min / max'
    assert math.min(3, 7) equals 3
    assert math.max(3, 7) equals 7

test 'ipow'
    assert math.ipow(2, 10) equals 1024
    assert math.ipow(3, 4) equals 81
    assert math.ipow(7, 0) equals 1

test 'map_range'
    v is math.map_range(5.0, 0.0, 10.0, 0.0, 100.0)
    assert v > 49.9
    assert v < 50.1

test 'is_nan / is_finite / is_inf'
    assert math.is_nan(math.NAN)
    assert math.is_finite(1.0)
    assert math.is_inf(math.INF)
