# N-6: query blocks now execute (where + delete + set).
store users
    name as String
    age as i64

*main
    insert users 'Alice', 30
    insert users 'Bob', 25
    insert users 'Charlie', 35

    # Read query block
    r is users query
        where age > 28 and name equals 'Alice'
    log r.name
    log r.age

    # Set query block
    users query
        where name equals 'Bob'
        set age is 26

    b is users where name equals 'Bob'
    log b.age

    # Delete query block
    users query
        where age > 28
        delete

    log(count users)
