# ── 30. Concurrency — Actors, Channels, Select ─────────────────────────────

# Actor definition — message handlers prefixed with @
actor Counter
    value as i64

    @increment self, amount as i64
        self.value += amount

    @get self
        self.value

# Supervisor — monitors child actors
# supervisor MySupervisor
#     strategy is one_for_one
#     children
#         Counter(value is 0)

# Channels — typed, buffered message passing
# ch is channel(10)              # buffered channel, capacity 10
# ch <- 42                       # send
# val is <-ch                    # receive

# Select — wait on multiple channels
# select
#     msg from inbox -> handle(msg)
#     tick from timer -> update()
#     default -> idle()

# Spawn — lightweight concurrent task
# task is spawn compute_heavy(data)


