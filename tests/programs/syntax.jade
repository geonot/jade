# ── 10. Pattern Matching ───────────────────────────────────────────────────

*describe_number(n)
    match n
        0 ? log('zero')
        1 ? log('one')
        _ ? log('other')

*area(s as Shape)
    match s
        Circle(r) ? 3 * r * r
        Rect(w, h) ? w * h
        Triangle(a, b, c) ? 0

