*increment(x)
    x + 1

*triple(x)
    x * 3

*demo_pipelines
    # ~ pipes left value as first argument to right function
    result is 10 ~ increment ~ triple ~ increment
    log(result)                  # 34 = ((10+1)*3)+1

    # Pipeline with extra arguments
    # val ~ fn(extra) → fn(val, extra)


# ── 7. Control Flow ────────────────────────────────────────────────────────

*demo_control_flow
    x is 10

    # If / elif / else
    if x > 5
        log('big')
    elif x > 3
        log('medium')
    else
        log('small')

    # Ternary: condition ? true_val ! false_val
    abs_x is x >= 0 ? x ! 0 - x
    log(abs_x)

    # If as expression (same ternary form)
    sign is x > 0 ? 1 ! -1
    log(sign)

    # While loop
    n is 5
    while n > 0
        log(n)
        n is n - 1

    # For loop as implicit assignment (assigns i starting from 0)
    for i from 0 to 5
        log(i)                   # 0, 1, 2, 3, 4

    # For with explicit assignment
    for i is 1 to 10
        log(i)                   # 1, 2, ..., 9

    # For with step
    for i from 0 to 20 by 3
        log(i)                   # 0, 3, 6, 9, 12, 15, 18

    # Infinite loop + break
    counter is 0
    loop
        if counter >= 3
            break
        counter is counter + 1

    # Yield — return a value from a loop
    found is loop
        if counter > 0
            yield counter

    # Continue
    i is 0
    while i < 10
        i is i + 1
        if i mod 2 equals 0
            continue
        log(i)

    # Labeled loops — binding name is the label
    outer is for i from 0 to 5
        for j from 0 to 5
            if i * j > 10
                break outer

    # Parallel loop (work-stealing), iterations must be independent
    # sim for x in [1, 2, 3, 4]
    #     log(x)

    # Range slicing
    items is [10, 20, 30, 40, 50]
    sub is items from 1 to 3      # [20, 30]
    log(sub[0])


# ── 8. Structs ──────────────────────────────────────────────────────────────

type Point
    x as i64
    y as i64

type Vec3
    x as i64
    y as i64
    z as i64

    # Methods — *name self, ... inside type body (parens optional)
    *length_squared self
        self.x * self.x + self.y * self.y + self.z * self.z

    *dot self, other as Vec3
        self.x * other.x + self.y * other.y + self.z * other.z

*demo_structs
    # Construction: named fields
    p is Point(x is 10, y is 20)
    log p.x
    log p.y

    v is Vec3(x is 1, y is 2, z is 3)
    log v.length_squared         # 14 — no-arg method call, no parens
    log v.dot v                  # 14 — method call, paren-free


