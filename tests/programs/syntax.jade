# ── 42. Scoped Imports ────────────────────────────────────────────────────

*demo_scoped_import
    use math [sin, cos]
    log(sin(0.0))


# ── 43. Einsum ────────────────────────────────────────────────────────────

*demo_einsum
    A is ndarray(2, 2)
    B is ndarray(2, 2)
    C is einsum 'ij,jk->ik', A, B


# ── 44. Grad ──────────────────────────────────────────────────────────────

*square(x as f64) returns f64
    x pow 2

*demo_grad
    dsquare is grad(square)              # derivative: 2x


# ── 45. Builder Blocks ───────────────────────────────────────────────────

*demo_builder
    cfg is build ServerConfig
        port is 8080
        host is 'localhost'


# ── 46. Of-Call Syntax ────────────────────────────────────────────────────

*demo_of_call
    result is double of 5               # same as double(5)


