# ── 16. String Operations ──────────────────────────────────────────────────

*demo_strings
    s is 'hello jade'

    # String methods
    log(s.contains('jade'))       # true
    log(s.starts_with('hello'))   # true
    log(s.ends_with('jade'))      # true
    log(s.char_at(0))             # 104 (ascii 'h')
    log(s.to_upper())             # HELLO JADE
    log(s.to_lower())             # hello jade
    log(s.trim())                 # hello jade
    log(s.replace('jade', 'world'))  # hello world

