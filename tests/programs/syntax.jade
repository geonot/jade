# ── 19. Systems Builtins ───────────────────────────────────────────────────

*demo_systems
    # Bit manipulation builtins
    log(popcount(0xFF))          # 8
    log(clz(1))                  # 63 (for i64)
    log(ctz(8))                  # 3
    log(bswap(0x0102030405060708))

    # Integer overflow control
    big is 9223372036854775807   # i64 max
    w is wrapping_add(big, 1)    # wraps to i64 min
    s is saturating_add(big, 1)  # stays at i64 max
    log(w)
    log(s)

    # Checked arithmetic — returns (result, overflowed)
    result, overflowed is checked_add(big, 1)
    if overflowed
        log('overflow detected')

    # Rotate
    log(rotate_left(1, 3))       # 8
    log(rotate_right(8, 3))      # 1

    # Atomic operations — lock-free thread-safe primitives
    counter is 0
    atomic_store(&counter, 10)
    log(atomic_load(&counter))           # 10
    atomic_add(&counter, 5)
    log(atomic_load(&counter))           # 15
    old is atomic_cas(&counter, 15, 20)  # compare-and-swap
    log(old)                             # 15

    # Arena allocation — bump allocator, freed all at once
    # arena is Arena(1024)
    # p is arena.alloc(64)
    # arena.reset()

    # Constant-time operations — for crypto / timing-safe code
    a is 42
    b is 42
    log(ct_eq(a, b))             # 1 (constant-time equality)
    log(ct_select(1, 10, 20))    # 10 (constant-time conditional select)


