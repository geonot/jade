    joined is parts.join('-')     # a-b-c
    log(joined)

    # Lines
    text is 'line1\nline2\nline3'
    for line in text.lines()
        log(line)

    # Find
    idx is s.find('jade')         # 6
    log(idx)

    # String interpolation
    name is 'world'
    log('hello {name}')
    x is 42
    log('value is {x}, doubled is {x * 2}')

    # Slicing
    sub is s.slice(0, 5)
    log(sub)                      # hello


