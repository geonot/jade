# ── 31. Persistent Stores (0.2.0 — planned) ────────────────────────────────
# Jade treats persistence as a first-class language feature.
# Stores are typed, transactional, and queryable — no ORM layer.

# store Users
#     name: String
#     email: String
#     age: i64
#
# store Posts
#     title: String
#     body: String
#     author: String
#     likes: i64
#
# *demo_stores
#     # Insert records
#     Users.insert name is 'alice', email is 'alice@jade.dev', age is 30
#     Users.insert name is 'bob', email is 'bob@jade.dev', age is 25
#
#     # Query — returns matching records
#     admins is Users.where age >= 18
#
#     # Update
#     Users.where(name equals 'bob').set age is 26
#
#     # Delete
#     Users.where(name equals 'alice').delete
#
#     # Transactions — atomic, all-or-nothing
#     transaction
#         Posts.insert title is 'hello', body is 'first post', author is 'alice', likes is 0
#         Users.where(name equals 'alice').set age is 31
#
#     # Count
#     log Users.count
#
#     # Iterate
#     for user from Users.all
#         log user.name


