# ── 1. Primitives & Literals ────────────────────────────────────────────────

*primitives
    # Integer types as i8, i16, i32, i64, u8, u16, u32, u64
    a is 42                     # inferred i64
    b as i32 is 100               # explicit type annotation
    c as u8 is 255

    # Float types as f32, f64
    pi is 3.14159               # inferred f64
    e as f32 is 2.718

    # Boolean
    yes is true
    no is false

    # Void (unit type)
    # Functions that return nothing return void implicitly

    # Integer literal formats
    hex is 0xFF
    bin is 0b10101010
    oct is 0o777
    big is 1_000_000            # underscores for readability

    # Negative literals
    neg is -42

    # Strings — single quotes, with {interpolation}
    name is 'jade'
    greeting is 'hello {name}'
    expr_interp is 'two plus two is {2 + 2}'

    log(a)
    log(pi)
    log(hex)
    log(greeting)


# ── 2. Bindings ─────────────────────────────────────────────────────────────

*bindings
    # Basic binding with `is`
    x is 10

    # Rebinding (same name, new value)
    x is x + 1

    # Typed binding
    count as i32 is 0

    # Augmented assignment (desugars to rebinding)
    x += 5              # x is x + 5
    x -= 2              # x is x - 2
    x *= 3              # x is x * 3
    x /= 4              # x is x / 4

    # Bitwise augmented assignment
    flags is 0
    flags |= 0x80       # flags is flags | 0x80
    flags &= 0xFF       # flags is flags & 0xFF
    flags ^= 0x0F       # flags is flags ^ 0x0F
    flags <<= 2         # flags is flags << 2
    flags >>= 1         # flags is flags >> 1

    log(x)


# ── 3. Operators ────────────────────────────────────────────────────────────

*operators
    # Arithmetic: + - * / mod pow
    log(2 + 3)           # 5
    log(10 - 4)          # 6
    log(6 * 7)           # 42
    log(15 / 4)          # 3 (integer division)
    log(17 mod 5)          # 2
    log(2 pow 10)         # 1024

    # Comparison: < > <= >=
    log(3 < 5)           # true
    log(5 >= 5)          # true

    # Equality: equals, neq (NOT == or !=)
    log(7 equals 7)      # true
    log(7 neq 8)        # true

    # Logical: and, or, xor, not (NOT &&, ||, !)
    log(true and false)  # false
    log(true or false)   # true
    log(true xor false)  # true
    log(not true)        # false

    # `in` membership
    log(3 in [1, 2, 3])  # true

    # Comparison chaining
    x is 5
    log(0 < x < 10)     # true (both comparisons must hold)

    # Bitwise: & | ^ << >> ~
    log(0xFF & 0x0F)     # 15
    log(0xF0 | 0x0F)     # 255
    log(0xFF ^ 0x0F)     # 240
    log(1 << 10)         # 1024
    log(1024 >> 5)       # 32

    # Type casting with `as`
    x is 42
    y is x as f64        # 42.0
    z is 3.99 as i64     # 3 (truncation)
    log(y)
    log(z)

    # Strict (narrowing) cast — panics if value does not fit
    big is 300
    # small is big as strict u8  # panics: 300 > 255

    # Serialisation casts
    # data is obj as json   # convert to JSON string
    # m is data as map      # convert back to map


# ── 4. Functions ────────────────────────────────────────────────────────────

# Function definition: * prefix, parameters infer types
# Parentheses are optional — both forms are valid
*add(a, b)
    a + b                       # implicit return (last expression)

*subtract a, b                  # paren-free definition
    a - b

# Explicit return
*factorial(n)
    if n <= 1
        return 1
    return n * factorial(n - 1)

# Typed parameters
*greet name as String
    log 'hello {name}'

# Default parameters
*connect host as String, port as i64 is 8080
    log 'connecting to {host}:{port}'

# Multiple return values (tuples)
*divmod(a, b)
    (a / b, a mod b)

# No-arg functions — no parens needed
*hello
    log 'hello'

# Recursion
*fib(n)
    if n < 2
        return n
    fib(n - 1) + fib(n - 2)

# Infinite recursion — no parens, no args
*spin
    spin

*demo_functions
    log(add(3, 4))               # 7  — parens call
    log add 3, 4                 # 7  — paren-free call
    log subtract 10, 3           # 7  — paren-free
    log(factorial(10))           # 3628800
    log(fib(10))                 # 55
    q, r is divmod 17, 5
    log(q)                       # 3
    log(r)                       # 2
    hello                        # no-arg call

    # Named arguments — `is` keyword inside call
    connect(host is 'localhost', port is 3000)

    # $ placeholder — creates anonymous lambda
    double is $($ * 2)           # |x| x * 2
    log(double(21))              # 42


# ── 5. Higher-Order Functions & Lambdas ─────────────────────────────────────

# Function type as (ParamTypes) returns ReturnType
*apply(f as (i64) returns i64, x as i64)
    f(x)

*demo_higher_order
    # Lambda: |params| body
    double is |x as i64| x * 2
    log(apply(double, 21))       # 42

    square is |x as i64| x * x
    log(apply(square, 7))        # 49

    # Multi-line lambda — just indent the body
    transform is |x as i64|
        y is x * 2
        y + 1
    log(transform(10))           # 21


