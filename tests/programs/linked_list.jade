# linked_list.jade — Singly linked list with enum + generics
# Complexity: Intermediate
# Demonstrates: recursive enums, generics, pattern matching, methods

enum List of T
    Cons(T, List of T)
    Nil

*list_length of T(lst: List of T)
    match lst
        Nil ? 0
        Cons(_, rest) ? 1 + list_length(rest)

*list_sum(lst: List of i64)
    match lst
        Nil ? 0
        Cons(val, rest) ? val + list_sum(rest)

*list_contains(lst: List of i64, target: i64)
    match lst
        Nil ? false
        Cons(val, rest) ?
            if val equals target
                true
            else
                list_contains(rest, target)

*list_reverse_acc(lst: List of i64, acc: List of i64)
    match lst
        Nil ? acc
        Cons(val, rest) ? list_reverse_acc(rest, Cons(val, acc))

*list_reverse(lst: List of i64)
    list_reverse_acc(lst, Nil)

*main()
    # Build a list: 1, 2, 3, 4, 5
    lst is Cons(1, Cons(2, Cons(3, Cons(4, Cons(5, Nil)))))

    log(list_length(lst))          # 5
    log(list_sum(lst))             # 15
    log(list_contains(lst, 3))     # true
    log(list_contains(lst, 9))     # false

    rev is list_reverse(lst)
    log(list_sum(rev))             # 15 (same sum)
