# primes.jade — Prime number algorithms
# Complexity: Beginner-Intermediate

*is_prime(n)
    if n < 2
        return false
    if n < 4
        return true
    if n % 2 equals 0
        return false
    d is 3
    while d * d <= n
        if n % d equals 0
            return false
        d is d + 2
    true

*count_primes(limit)
    count is 0
    for n from 2 to limit
        if is_prime(n)
            count is count + 1
    count

*nth_prime(n)
    count is 0
    candidate is 2
    loop
        if is_prime(candidate)
            count is count + 1
            if count equals n
                return candidate
        candidate is candidate + 1

*main()
    # Print first 20 primes
    for i from 2 to 80
        if is_prime(i)
            log(i)

    # Count primes below 1000
    log(count_primes(1000))       # 168

    # 100th prime
    log(nth_prime(100))           # 541
