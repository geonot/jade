# Test all loop patterns

*main
    # loop collection with $ (element)
    items is vec()
    items.push("a")
    items.push("b")
    items.push("c")
    loop items
        log($)

    # loop collection with $$ (index)
    loop items
        log(to_string($$) + ":" + $)

    # loop range with $ (value)
    loop 0 to 3
        log(to_string($))

    # loop range with $$ (0-based index)
    loop 5 to 8
        log(to_string($$) + "=" + to_string($))

    # loop range with step
    loop 0 to 10 by 3
        log(to_string($))

    # loop 1 to 5 — first iteration $ is 1, $$ is 0
    loop 1 to 4
        log(to_string($$) + ">" + to_string($))

    # for-range still works
    for i in 0 to 3
        log(to_string(i))
