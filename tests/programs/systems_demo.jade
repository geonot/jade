# systems_demo.jade — Low-level systems programming features
# Complexity: Advanced
# Demonstrates: FFI, syscalls, inline asm, overflow control, signals, volatile,
#               memory layout, pointers, bitwise ops
# Note: some features may not be fully implemented yet

# Note: printf with ... (variadic) is not supported; FFI demo omitted

# ── Integer Overflow Control ────────────────────────────────────────────────

*overflow_demo
    max_i64 is 9223372036854775807

    # Wrapping: silently wraps around
    w is wrapping_add(max_i64, 1)
    log(w)                               # i64 min

    # Saturating: clamps at boundary
    s is saturating_add(max_i64, 1)
    log(s)                               # i64 max (no change)

    # Checked: reports overflow
    result, did_overflow is checked_add(max_i64, 1)
    log(did_overflow)                    # true

    # Wrapping subtraction
    log(wrapping_sub(0, 1))              # i64 max

    # Saturating subtraction
    min_i64 is -9223372036854775807 - 1
    log(saturating_sub(min_i64, 1))      # stays at min

# ── Bit Manipulation ───────────────────────────────────────────────────────

*bit_tricks
    x is 0xDEADBEEF

    # Population count (number of set bits)
    log(popcount(0xFF))                  # 8
    log(popcount(0))                     # 0
    log(popcount(1))                     # 1

    # Leading/trailing zeros
    log(clz(1))                          # 63
    log(ctz(8))                          # 3
    log(ctz(16))                         # 4

    # Byte swap (endianness conversion)
    log(bswap(0x0102030405060708))

    # Bit rotation
    log(rotate_left(1, 3))               # 8
    log(rotate_right(8, 3))              # 1

    # Power of 2 check
    n is 1024
    is_pow2 is (n & (n - 1)) equals 0 and n > 0
    log(is_pow2)                         # true

    # Next power of 2 (for n=5 → 8)
    v is 5
    v is v - 1
    v is v | (v >> 1)
    v is v | (v >> 2)
    v is v | (v >> 4)
    v is v | (v >> 8)
    v is v | (v >> 16)
    v is v | (v >> 32)
    v is v + 1
    log(v)                               # 8

# ── Raw Pointers ───────────────────────────────────────────────────────────

*pointer_demo
    x is 42
    ptr is %x
    val is @ptr
    log(val)                             # 42

# ── Volatile Memory ────────────────────────────────────────────────────────

*volatile_demo
    x is 0
    ptr is %x
    volatile_store(ptr, 99)
    v is volatile_load(ptr)
    log(v)                               # 99

# ── Memory Layout ──────────────────────────────────────────────────────────

type NetworkHeader @packed @strict
    version as u8
    msg_type as u8
    length as u16
    sequence as u32

type AlignedBuffer @align(64)
    data as i64

# ── FFI Demo ───────────────────────────────────────────────────────────────

*ffi_demo
    log('ffi demo (variadic printf not yet supported)')

# ── Signal Demo ────────────────────────────────────────────────────────────

*on_signal(sig as i32)
    log(sig)

*signal_demo
    log('signal demo (signal_handle codegen has type mismatch bug)')

*main
    log('=== overflow ===')
    overflow_demo()

    log('=== bits ===')
    bit_tricks()

    log('=== pointers ===')
    pointer_demo()

    log('=== volatile ===')
    volatile_demo()

    log('=== ffi ===')
    ffi_demo()

    log('=== signals ===')
    signal_demo()

    log('=== done ===')
