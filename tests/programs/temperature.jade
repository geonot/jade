# temperature.jade — Temperature conversion utilities
# Complexity: Beginner

*celsius_to_fahrenheit(c)
    c * 9.0 / 5.0 + 32.0

*fahrenheit_to_celsius(f)
    (f - 32.0) * 5.0 / 9.0

*celsius_to_kelvin(c)
    c + 273.15

*classify(c)
    if c < 0.0
        log('freezing')
    elif c < 20.0
        log('cold')
    elif c < 30.0
        log('comfortable')
    else
        log('hot')

*main
    temps is [0.0, 20.0, 37.0, 100.0, -40.0]
    for i from 0 to 5
        c is temps[i]
        f is celsius_to_fahrenheit(c)
        k is celsius_to_kelvin(c)
        log(c)
        log(f)
        log(k)
        classify(c)
