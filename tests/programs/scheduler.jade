# scheduler.jade — Task scheduler with priority queue simulation
# Complexity: Intermediate-Advanced
# Demonstrates: structs, enums, methods, arrays, sorting, pattern matching

enum Priority
    Critical
    High
    Normal
    Low

enum TaskStatus
    Pending
    Running
    Complete
    Failed(String)

type Task
    id: i64
    priority: Priority
    deadline: i64
    status: TaskStatus

*priority_value(p: Priority)
    match p
        Critical ? 0
        High ? 1
        Normal ? 2
        Low ? 3

*is_pending(task: Task)
    match task.status
        Pending ? true
        _ ? false

*task_info(task: Task)
    log(task.id)
    match task.priority
        Critical ? log('CRITICAL')
        High ? log('HIGH')
        Normal ? log('NORMAL')
        Low ? log('LOW')
    match task.status
        Pending ? log('pending')
        Running ? log('running')
        Complete ? log('complete')
        Failed(reason) ? log(reason)

# Find highest priority pending task
*find_next(tasks, count: i64)
    best_idx is -1
    best_prio is 99
    for i from 0 to count
        if is_pending(tasks[i])
            p is priority_value(tasks[i].priority)
            if p < best_prio
                best_prio is p
                best_idx is i
    best_idx

# Count tasks by status
*count_complete(tasks, count: i64)
    total is 0
    for i from 0 to count
        match tasks[i].status
            Complete ? total is total + 1
            _ ? total is total
    total

*count_pending(tasks, count: i64)
    total is 0
    for i from 0 to count
        if is_pending(tasks[i])
            total is total + 1
    total

*main()
    # Create a set of tasks
    tasks is [
        Task(id is 1, priority is Low, deadline is 100, status is Pending),
        Task(id is 2, priority is Critical, deadline is 10, status is Pending),
        Task(id is 3, priority is Normal, deadline is 50, status is Pending),
        Task(id is 4, priority is High, deadline is 30, status is Pending),
        Task(id is 5, priority is Normal, deadline is 60, status is Pending)
    ]

    count is 5
    log(count_pending(tasks, count))     # 5

    # Process tasks by priority
    processed is 0
    loop
        next is find_next(tasks, count)
        if next equals -1
            break

        task_info(tasks[next])
        # Mark as complete
        t is tasks[next]
        tasks[next] is Task(id is t.id, priority is t.priority, deadline is t.deadline, status is Complete)
        processed is processed + 1

    log(processed)                       # 5
    log(count_complete(tasks, count))    # 5
    log(count_pending(tasks, count))     # 0
