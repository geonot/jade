# Parallel Fibonacci - Sequential vs Sim For
# Demonstrates real multicore speedup with sim for
# Uses varying inputs fib(35+i) to prevent LLVM LICM optimization

extern *jade_time_now_ns() returns i64

*fib(n as i64) returns i64
    if n < 2
        n
    else
        fib(n - 1) + fib(n - 2)

*main
    # --- Sequential: compute fib(35)..fib(42) one at a time ---
    t0 is jade_time_now_ns()
    for i in 8
        log(fib(35 + i))
    t1 is jade_time_now_ns()
    seq_ms is (t1 - t0) / 1000000
    log(seq_ms)

    # --- Parallel: compute fib(35)..fib(42) via sim for ---
    t2 is jade_time_now_ns()
    sim for i in 8
        log(fib(35 + i))
    t3 is jade_time_now_ns()
    par_ms is (t3 - t2) / 1000000
    log(par_ms)

    log(0)
