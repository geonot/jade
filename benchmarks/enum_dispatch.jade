enum Op
    Add(i64, i64)
    Mul(i64, i64)
    Neg(i64)

*eval(op as Op)
    match op
        Add(a, b) ? a + b
        Mul(a, b) ? a * b
        Neg(a) ? 0 - a

*main
    total is 0
    i is 0
    while i < 2000000000
        total is total + eval(Add(i, i + 1))
        total is total + eval(Mul(i, 2))
        total is total + eval(Neg(i))
        total is total xor i
        i is i + 1
    log(total)
    0
