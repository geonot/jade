store records
    key
    value

*main
    # Insert 10000 records
    for i in 0 to 10000
        insert records i, i * 7

    # Query 1000 times
    total is 0
    for j in 0 to 1000
        r is records where key equals j
        total is total + r.value

    log(total)

    # Count
    c is count records
    log(c)
