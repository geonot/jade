# std.terminal — ANSI terminal control: colors, cursor, raw mode
#
# A self-contained ANSI escape-sequence helper. No tput / terminfo
# dependency — assumes a VT100/xterm-compatible terminal (every
# mainstream emulator since 1990).
#
# Usage:
#   print(terminal.bold(terminal.red("Error: ")) + msg)
#   terminal.clear()
#   terminal.move_to(1, 1)
#   if terminal.is_tty()
#       terminal.hide_cursor()
#
# For raw-mode line editing or full-screen UIs, use `enable_raw()` /
# `disable_raw()` and read with `std.io.read_byte`.

extern *isatty(fd as i32) returns i32
extern *jade_terminal_enable_raw(fd as i32) returns i32
extern *jade_terminal_disable_raw(fd as i32) returns i32
extern *jade_terminal_size(out_cols as %i32, out_rows as %i32) returns i32
extern *write(fd as i32, buf as %i8, len as i64) returns i64
extern *malloc(size as i64) returns %i8
extern *free(ptr as %i8)

ESC is "\x1b"
CSI is "\x1b["

# ── ANSI 8-color foreground ──────────────────────────────────

*black(s as String) returns String
    CSI + "30m" + s + CSI + "0m"

*red(s as String) returns String
    CSI + "31m" + s + CSI + "0m"

*green(s as String) returns String
    CSI + "32m" + s + CSI + "0m"

*yellow(s as String) returns String
    CSI + "33m" + s + CSI + "0m"

*blue(s as String) returns String
    CSI + "34m" + s + CSI + "0m"

*magenta(s as String) returns String
    CSI + "35m" + s + CSI + "0m"

*cyan(s as String) returns String
    CSI + "36m" + s + CSI + "0m"

*white(s as String) returns String
    CSI + "37m" + s + CSI + "0m"

# ── Bright foreground variants ───────────────────────────────

*bright_red(s as String) returns String
    CSI + "91m" + s + CSI + "0m"

*bright_green(s as String) returns String
    CSI + "92m" + s + CSI + "0m"

*bright_yellow(s as String) returns String
    CSI + "93m" + s + CSI + "0m"

*bright_blue(s as String) returns String
    CSI + "94m" + s + CSI + "0m"

# ── 24-bit truecolor ─────────────────────────────────────────

*rgb(r as i64, g as i64, b as i64, s as String) returns String
    CSI + "38;2;" + r + ";" + g + ";" + b + "m" + s + CSI + "0m"

*bg_rgb(r as i64, g as i64, b as i64, s as String) returns String
    CSI + "48;2;" + r + ";" + g + ";" + b + "m" + s + CSI + "0m"

# ── Text attributes ──────────────────────────────────────────

*bold(s as String) returns String
    CSI + "1m" + s + CSI + "22m"

*dim(s as String) returns String
    CSI + "2m" + s + CSI + "22m"

*italic(s as String) returns String
    CSI + "3m" + s + CSI + "23m"

*underline(s as String) returns String
    CSI + "4m" + s + CSI + "24m"

*reverse(s as String) returns String
    CSI + "7m" + s + CSI + "27m"

*strikethrough(s as String) returns String
    CSI + "9m" + s + CSI + "29m"

*reset returns String
    CSI + "0m"

# ── Screen control ───────────────────────────────────────────

*clear
    print(CSI + "2J" + CSI + "H")

*clear_line
    print(CSI + "2K\r")

*clear_to_end
    print(CSI + "0J")

# Move cursor to absolute (row, col). 1-indexed (top-left = 1,1).
*move_to(row as i64, col as i64)
    print(CSI + row + ";" + col + "H")

*move_up(n as i64)
    print(CSI + n + "A")

*move_down(n as i64)
    print(CSI + n + "B")

*move_right(n as i64)
    print(CSI + n + "C")

*move_left(n as i64)
    print(CSI + n + "D")

*save_cursor
    print(ESC + "7")

*restore_cursor
    print(ESC + "8")

*hide_cursor
    print(CSI + "?25l")

*show_cursor
    print(CSI + "?25h")

# Alt screen buffer (for full-screen apps).
*enter_alt_screen
    print(CSI + "?1049h")

*leave_alt_screen
    print(CSI + "?1049l")

# ── Terminal state ───────────────────────────────────────────

*is_tty returns bool
    extern.isatty(1) equals 1

*is_stderr_tty returns bool
    extern.isatty(2) equals 1

# Enable raw mode on stdin (no echo, no canonical line buffering).
# Returns true on success. Pair with `disable_raw()`.
*enable_raw returns bool
    extern.jade_terminal_enable_raw(0) equals 0

*disable_raw returns bool
    extern.jade_terminal_disable_raw(0) equals 0

# ── Size detection ───────────────────────────────────────────

type Size
    cols as i32
    rows as i32

*size returns Size
    cols_buf is extern.malloc(4)
    rows_buf is extern.malloc(4)
    rc is extern.jade_terminal_size(cols_buf, rows_buf)
    if rc neq 0
        extern.free(cols_buf)
        extern.free(rows_buf)
        return Size(cols is 80, rows is 24)
    cols is __i32_load(cols_buf)
    rows is __i32_load(rows_buf)
    extern.free(cols_buf)
    extern.free(rows_buf)
    Size(cols is cols, rows is rows)

# ── Strip ANSI for length / non-tty output ──────────────────

# Remove all ANSI escape sequences from `s`.
*strip(s as String) returns String
    out is ""
    i is 0
    while i < s.length
        if s.char_at(i) equals 27 and i + 1 < s.length and s.char_at(i + 1) equals 91
            # CSI: skip until letter
            i is i + 2
            while i < s.length
                c is s.char_at(i)
                i is i + 1
                if (c >= 64 and c <= 126)
                    break
        else
            out is out + s.slice(i, i + 1)
            i is i + 1
    out

# Visible width (count of code points after stripping ANSI).
*visible_width(s as String) returns i64
    strip(s).length

# ── Conditional coloring (respects NO_COLOR / non-tty) ──────
#
# NO_COLOR convention: https://no-color.org

*color_enabled returns bool
    if not is_tty()
        return false
    if __getenv("NO_COLOR").length > 0
        return false
    true

# Apply a color function only when output is a TTY and NO_COLOR unset.
*colorize(s as String, color_name as String) returns String
    if not color_enabled()
        return s
    if color_name equals "red"
        return red(s)
    if color_name equals "green"
        return green(s)
    if color_name equals "yellow"
        return yellow(s)
    if color_name equals "blue"
        return blue(s)
    if color_name equals "cyan"
        return cyan(s)
    if color_name equals "magenta"
        return magenta(s)
    if color_name equals "bold"
        return bold(s)
    s
