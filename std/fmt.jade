# std.fmt — String formatting

*float_to_string(x, decimals)
    __fmt_float(x, decimals)

*hex(n)
    __fmt_hex(n)

*oct(n)
    __fmt_oct(n)

*bin(n)
    __fmt_bin(n)

*pad_left(s as String, width, fill as String)
    if s.length >= width
        return s
    padding is width - s.length
    result is ""
    i is 0
    while i < padding
        result is result + fill
        i is i + 1
    result + s

*pad_right(s as String, width, fill as String)
    if s.length >= width
        return s
    padding is width - s.length
    result is s
    i is 0
    while i < padding
        result is result + fill
        i is i + 1
    result

*join(items, sep as String)
    if items.length equals 0
        return ""
    result is items.get(0)
    i is 1
    while i < items.length
        result is result + sep + items.get(i)
        i is i + 1
    result

*repeat(s as String, n)
    result is ""
    i is 0
    while i < n
        result is result + s
        i is i + 1
    result
