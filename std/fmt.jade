# std.fmt — String formatting
#
# Usage:
#   fmt.hex(255)          # "ff"
#   fmt.pad_left("5", 3, "0")  # "005"

*float(x, decimals)
    __fmt_float(x, decimals)

*hex(n)
    __fmt_hex(n)

*oct(n)
    __fmt_oct(n)

*bin(n)
    __fmt_bin(n)

*pad_left(s as String, width, fill as String)
    if s.length >= width
        return s
    padding is width - s.length
    result is ""
    for i in 0 to padding
        result is result + fill
    result + s

*pad_right(s as String, width, fill as String)
    if s.length >= width
        return s
    padding is width - s.length
    result is s
    for i in 0 to padding
        result is result + fill
    result

*join(items, sep as String)
    if items.length equals 0
        return ""
    result is ""
    loop items
        if $$ > 0
            result is result + sep
        result is result + $
    result

*repeat(s as String, n)
    result is ""
    for i in 0 to n
        result is result + s
    result

*center(s as String, width, fill as String)
    if s.length >= width
        return s
    total_pad is width - s.length
    left_pad is total_pad / 2
    right_pad is total_pad - left_pad
    result is ""
    for i in 0 to left_pad
        result is result + fill
    result is result + s
    for i in 0 to right_pad
        result is result + fill
    result

*truncate(s as String, max_len, suffix as String)
    if s.length <= max_len
        return s
    s.slice(0, max_len - suffix.length) + suffix
