# std.complex — Complex number arithmetic and elementary functions
#
# Standards-aligned with Annex G of C99 / C++ <complex>:
#   * Cartesian and polar constructors.
#   * Field operations (+ − × ÷, conjugate, reciprocal, scaling).
#   * Norm, magnitude, phase.
#   * Transcendental: exp, log, pow, sqrt, sin, cos, tan, sinh, cosh.
#
# Usage:
#   z is complex.new(3.0, 4.0)
#   complex.magnitude(z)        # 5.0
#   complex.phase(z)            # ≈ 0.927
#   w is complex.exp(complex.mul(z, complex.i()))

extern *sqrt(x as f64) returns f64
extern *exp(x as f64) returns f64
extern *log(x as f64) returns f64
extern *pow(x as f64, y as f64) returns f64
extern *atan2(y as f64, x as f64) returns f64
extern *cos(x as f64) returns f64
extern *sin(x as f64) returns f64
extern *cosh(x as f64) returns f64
extern *sinh(x as f64) returns f64
extern *fabs(x as f64) returns f64
extern *hypot(x as f64, y as f64) returns f64

PI is 3.14159265358979323846
TAU is 6.28318530717958647692
E is 2.71828182845904523536

type Complex
    re as f64
    im as f64

# ── Constructors ─────────────────────────────────────────────

*new(re as f64, im as f64) returns Complex
    Complex(re is re, im is im)

*from_real(x as f64) returns Complex
    Complex(re is x, im is 0.0)

*from_polar(r as f64, theta as f64) returns Complex
    Complex(re is r * extern.cos(theta), im is r * extern.sin(theta))

*zero returns Complex
    Complex(re is 0.0, im is 0.0)

*one returns Complex
    Complex(re is 1.0, im is 0.0)

*i returns Complex
    Complex(re is 0.0, im is 1.0)

# ── Field ────────────────────────────────────────────────────

*add(a as Complex, b as Complex) returns Complex
    Complex(re is a.re + b.re, im is a.im + b.im)

*sub(a as Complex, b as Complex) returns Complex
    Complex(re is a.re - b.re, im is a.im - b.im)

*mul(a as Complex, b as Complex) returns Complex
    Complex(re is a.re * b.re - a.im * b.im, im is a.re * b.im + a.im * b.re)

*div(a as Complex, b as Complex) returns Complex
    denom is b.re * b.re + b.im * b.im
    Complex(re is (a.re * b.re + a.im * b.im) / denom, im is (a.im * b.re - a.re * b.im) / denom)

*negate(z as Complex) returns Complex
    Complex(re is 0.0 - z.re, im is 0.0 - z.im)

*conjugate(z as Complex) returns Complex
    Complex(re is z.re, im is 0.0 - z.im)

*scale(z as Complex, s as f64) returns Complex
    Complex(re is z.re * s, im is z.im * s)

*reciprocal(z as Complex) returns Complex
    d is z.re * z.re + z.im * z.im
    Complex(re is z.re / d, im is (0.0 - z.im) / d)

# ── Norms ────────────────────────────────────────────────────

*norm_sq(z as Complex) returns f64
    z.re * z.re + z.im * z.im

# Hypot-based magnitude avoids overflow for very large components.
*magnitude(z as Complex) returns f64
    extern.hypot(z.re, z.im)

*abs(z as Complex) returns f64
    magnitude(z)

*phase(z as Complex) returns f64
    extern.atan2(z.im, z.re)

# ── Comparison ───────────────────────────────────────────────

*is_equal(a as Complex, b as Complex) returns bool
    extern.fabs(a.re - b.re) < 1e-12 and extern.fabs(a.im - b.im) < 1e-12

*is_zero(z as Complex) returns bool
    extern.fabs(z.re) < 1e-15 and extern.fabs(z.im) < 1e-15

# ── Transcendental functions ─────────────────────────────────

# exp(z) = e^x · (cos y + i sin y)
*exp(z as Complex) returns Complex
    e_re is extern.exp(z.re)
    Complex(re is e_re * extern.cos(z.im), im is e_re * extern.sin(z.im))

# log(z) = log|z| + i·arg(z) (principal branch)
*log(z as Complex) returns Complex
    Complex(re is extern.log(magnitude(z)), im is extern.atan2(z.im, z.re))

# z^w = exp(w · log z)
*pow(z as Complex, w as Complex) returns Complex
    if is_zero(z)
        return zero()
    exp(mul(w, log(z)))

# Principal square root.
*sqrt(z as Complex) returns Complex
    r is magnitude(z)
    if r equals 0.0
        return zero()
    sign is z.im < 0.0 ? -1.0 ! 1.0
    re is extern.sqrt((r + z.re) * 0.5)
    im is sign * extern.sqrt((r - z.re) * 0.5)
    Complex(re is re, im is im)

*sin(z as Complex) returns Complex
    Complex(re is extern.sin(z.re) * extern.cosh(z.im), im is extern.cos(z.re) * extern.sinh(z.im))

*cos(z as Complex) returns Complex
    Complex(re is extern.cos(z.re) * extern.cosh(z.im), im is 0.0 - extern.sin(z.re) * extern.sinh(z.im))

*tan(z as Complex) returns Complex
    div(sin(z), cos(z))

*sinh(z as Complex) returns Complex
    Complex(re is extern.sinh(z.re) * extern.cos(z.im), im is extern.cosh(z.re) * extern.sin(z.im))

*cosh(z as Complex) returns Complex
    Complex(re is extern.cosh(z.re) * extern.cos(z.im), im is extern.sinh(z.re) * extern.sin(z.im))

# ── Formatting ───────────────────────────────────────────────

*to_string(z as Complex) returns String
    re_s is __fmt_float(z.re, 6)
    im_s is __fmt_float(z.im, 6)
    if z.im >= 0.0
        return re_s + "+" + im_s + "i"
    re_s + im_s + "i"
