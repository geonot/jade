# std.complex — Complex number arithmetic
#
# Usage:
#   a is complex.new(3.0, 4.0)
#   b is complex.new(1.0, 2.0)
#   c is complex.add(a, b)
#   log(complex.magnitude(a))   # 5.0

extern *sqrt(x as f64) returns f64
extern *atan2(y as f64, x as f64) returns f64
extern *cos(x as f64) returns f64
extern *sin(x as f64) returns f64
extern *fabs(x as f64) returns f64

PI is 3.14159265358979323846

type Complex
    re as f64
    im as f64

*new(re as f64, im as f64)
    Complex(re is re, im is im)

*from_polar(r as f64, theta as f64)
    Complex(re is r * extern.cos(theta), im is r * extern.sin(theta))

*add(a as Complex, b as Complex)
    Complex(re is a.re + b.re, im is a.im + b.im)

*sub(a as Complex, b as Complex)
    Complex(re is a.re - b.re, im is a.im - b.im)

*mul(a as Complex, b as Complex)
    Complex(re is a.re * b.re - a.im * b.im, im is a.re * b.im + a.im * b.re)

*div(a as Complex, b as Complex)
    denom is b.re * b.re + b.im * b.im
    Complex(re is (a.re * b.re + a.im * b.im) / denom, im is (a.im * b.re - a.re * b.im) / denom)

*magnitude(z as Complex) returns f64
    extern.sqrt(z.re * z.re + z.im * z.im)

*phase(z as Complex) returns f64
    extern.atan2(z.im, z.re)

*conjugate(z as Complex)
    Complex(re is z.re, im is 0.0 - z.im)

*negate(z as Complex)
    Complex(re is 0.0 - z.re, im is 0.0 - z.im)

*scale(z as Complex, s as f64)
    Complex(re is z.re * s, im is z.im * s)

*norm_sq(z as Complex) returns f64
    z.re * z.re + z.im * z.im

*reciprocal(z as Complex)
    d is norm_sq(z)
    Complex(re is z.re / d, im is (0.0 - z.im) / d)

*is_equal(a as Complex, b as Complex) returns bool
    extern.fabs(a.re - b.re) < 1e-12 and extern.fabs(a.im - b.im) < 1e-12

*to_string(z as Complex) returns String
    re_s is __fmt_float(z.re, 6)
    im_s is __fmt_float(z.im, 6)
    if z.im >= 0.0
        return re_s + "+" + im_s + "i"
    re_s + im_s + "i"

*zero
    Complex(re is 0.0, im is 0.0)

*one
    Complex(re is 1.0, im is 0.0)

*i
    Complex(re is 0.0, im is 1.0)
