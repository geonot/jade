# std.rational — Exact rational arithmetic (always reduced)
#
# Internally always stored in lowest terms with positive denominator,
# so equality is structural. No precision loss across +, −, ×, ÷.
#
# Usage:
#   a is rational.new(1, 3)        # 1/3
#   b is rational.new(2, 5)        # 2/5
#   rational.add(a, b).to_string() # "11/15"
#   rational.compare(a, b)         # -1, 0, or 1

type Rational
    num as i64
    den as i64

    *to_string returns String
        self.den equals 1 ? "" + self.num ! "" + self.num + "/" + self.den

    *to_f64 returns f64
        (self.num as f64) / (self.den as f64)

    *abs returns Rational
        n is self.num < 0 ? 0 - self.num ! self.num
        Rational(num is n, den is self.den)

    *negate returns Rational
        Rational(num is 0 - self.num, den is self.den)

    *reciprocal returns Rational
        __reduce(self.den, self.num)

    *is_zero returns bool
        self.num equals 0

    *is_positive returns bool
        self.num > 0

    *is_negative returns bool
        self.num < 0

    *is_integer returns bool
        self.den equals 1

# ── Constructors ─────────────────────────────────────────────

*new(num as i64, den as i64) returns Rational
    __reduce(num, den)

*from_int(n as i64) returns Rational
    Rational(num is n, den is 1)

# Convert a finite f64 to its exact rational using continued fractions.
# Caps denominator at `max_den` for usability.
*from_f64(x as f64, max_den as i64) returns Rational
    if x equals 0.0
        return Rational(num is 0, den is 1)
    sign is x < 0.0 ? -1 ! 1
    val is x < 0.0 ? 0.0 - x ! x
    h1 is 1
    h0 is 0
    k1 is 0
    k0 is 1
    a is val as i64
    while true
        h2 is a * h1 + h0
        k2 is a * k1 + k0
        if k2 > max_den
            break
        h0 is h1
        h1 is h2
        k0 is k1
        k1 is k2
        frac is val - (a as f64)
        if frac equals 0.0
            break
        val is 1.0 / frac
        a is val as i64
    Rational(num is sign * h1, den is k1)

# Parse "3/4" or "5".
*parse(s as String) returns Rational
    slash is s.find("/")
    if slash < 0
        return Rational(num is __atoi(s), den is 1)
    __reduce(__atoi(s.slice(0, slash)), __atoi(s.slice(slash + 1, s.length)))

# ── Constants ────────────────────────────────────────────────

*zero returns Rational
    Rational(num is 0, den is 1)

*one returns Rational
    Rational(num is 1, den is 1)

# ── Arithmetic ───────────────────────────────────────────────

*add(a as Rational, b as Rational) returns Rational
    __reduce(a.num * b.den + b.num * a.den, a.den * b.den)

*sub(a as Rational, b as Rational) returns Rational
    __reduce(a.num * b.den - b.num * a.den, a.den * b.den)

*mul(a as Rational, b as Rational) returns Rational
    __reduce(a.num * b.num, a.den * b.den)

*div(a as Rational, b as Rational) returns Rational
    __reduce(a.num * b.den, a.den * b.num)

# Integer power (negative exponents allowed).
*ipow(r as Rational, n as i64) returns Rational
    if n equals 0
        return one()
    if n < 0
        return ipow(r.reciprocal(), 0 - n)
    base is r
    result is one()
    e is n
    while e > 0
        if e mod 2 equals 1
            result is mul(result, base)
        base is mul(base, base)
        e is e / 2
    result

# Stern-Brocot mediant — useful for best-rational-approximation searches.
*mediant(a as Rational, b as Rational) returns Rational
    __reduce(a.num + b.num, a.den + b.den)

# ── Comparison ───────────────────────────────────────────────

# Returns -1, 0, or 1.
*compare(a as Rational, b as Rational) returns i64
    lhs is a.num * b.den
    rhs is b.num * a.den
    if lhs < rhs
        return -1
    if lhs > rhs
        return 1
    0

*is_equal(a as Rational, b as Rational) returns bool
    a.num equals b.num and a.den equals b.den

*less_than(a as Rational, b as Rational) returns bool
    compare(a, b) < 0

*greater_than(a as Rational, b as Rational) returns bool
    compare(a, b) > 0

*min(a as Rational, b as Rational) returns Rational
    less_than(a, b) ? a ! b

*max(a as Rational, b as Rational) returns Rational
    greater_than(a, b) ? a ! b

# ── Internal ─────────────────────────────────────────────────

*__gcd(a as i64, b as i64) returns i64
    x is a < 0 ? 0 - a ! a
    y is b < 0 ? 0 - b ! b
    while y neq 0
        t is y
        y is x mod y
        x is t
    x

*__reduce(num as i64, den as i64) returns Rational
    if den equals 0
        return Rational(num is 0, den is 1)
    g is __gcd(num, den)
    n is num / g
    d is den / g
    if d < 0
        n is 0 - n
        d is 0 - d
    Rational(num is n, den is d)

*__atoi(s as String) returns i64
    n is 0
    sign is 1
    i is 0
    if s.length > 0 and s.char_at(0) equals 45
        sign is -1
        i is 1
    while i < s.length
        c is s.char_at(i)
        if c < 48 or c > 57
            break
        n is n * 10 + (c - 48)
        i is i + 1
    n * sign
