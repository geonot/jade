# std.cli — Command-line argument parser
#
# Usage:
#   parser is cli.new_parser("myapp", "A tool that does things")
#   parser.flag("verbose", "v", "Enable verbose output")
#   parser.option("output", "o", "Output file path")
#   args is parser.parse()
#   if args.has("verbose") ...
#   out_file is args.get("output")

type ParsedArgs
    flags as Map of i64
    options as Map of String
    positional as Vec of String

    *has(name as String) returns bool
        if self.flags.get(name) equals 1
            return true
        self.options.has(name)

    *get(name as String) returns String
        if self.options.has(name)
            return self.options.get(name)
        ""

    *is_set(name as String) returns bool
        self.flags.get(name) equals 1

    *args
        self.positional

type ArgParser
    name as String
    description as String
    def_names as Vec of String
    def_shorts as Vec of String
    def_descs as Vec of String
    def_is_flag as Vec of i64

    *flag(name as String, short as String, desc as String)
        self.def_names.push(name)
        self.def_shorts.push(short)
        self.def_descs.push(desc)
        self.def_is_flag.push(1)

    *option(name as String, short as String, desc as String)
        self.def_names.push(name)
        self.def_shorts.push(short)
        self.def_descs.push(desc)
        self.def_is_flag.push(0)

    *parse returns ParsedArgs
        raw is __get_args()
        flags is map()
        options is map()
        positional is vec()
        i is 1
        while i < raw.length
            arg is raw.get(i)
            if arg.starts_with("--")
                # Long option
                key is arg.slice(2, arg.length)
                eq_pos is key.find("=")
                if eq_pos > 0
                    oname is key.slice(0, eq_pos)
                    val is key.slice(eq_pos + 1, key.length)
                    options.set(oname, val)
                else
                    if __is_flag(self.def_names, self.def_is_flag, key)
                        flags.set(key, 1)
                    elif i + 1 < raw.length
                        i is i + 1
                        options.set(key, raw.get(i))
                    else
                        flags.set(key, 1)
            elif arg.starts_with("-") and arg.length > 1
                # Short option(s)
                j is 1
                while j < arg.length
                    ch is arg.slice(j, j + 1)
                    found_name is __find_by_short(self.def_names, self.def_shorts, ch)
                    is_flag is __is_flag(self.def_names, self.def_is_flag, found_name)
                    if is_flag
                        flags.set(found_name, 1)
                    elif j + 1 equals arg.length and i + 1 < raw.length
                        i is i + 1
                        options.set(found_name, raw.get(i))
                    else
                        flags.set(found_name, 1)
                    j is j + 1
            else
                positional.push(arg)
            i is i + 1
        ParsedArgs(flags is flags, options is options, positional is positional)

    *help returns String
        result is self.name + " — " + self.description + "\n\nOptions:\n"
        loop self.def_names
            line is "  --" + $
            s is self.def_shorts.get($$)
            if s.length > 0
                line is line + ", -" + s
            line is line + "  " + self.def_descs.get($$)
            if self.def_is_flag.get($$) equals 0
                line is line + " <value>"
            result is result + line + "\n"
        result

*new_parser(name as String, desc as String) returns ArgParser
    ArgParser(name is name, description is desc, def_names is vec(), def_shorts is vec(), def_descs is vec(), def_is_flag is vec())

*__is_flag(names as Vec of String, flags as Vec of i64, name as String) returns bool
    loop names
        if $ equals name
            return flags.get($$) equals 1
    true

*__find_by_short(names as Vec of String, shorts as Vec of String, short as String) returns String
    loop shorts
        if $ equals short
            return names.get($$)
    short
