# std.math — Mathematics
# Constants and functions built on LLVM intrinsic builtins

PI is 3.14159265358979323846
E is 2.71828182845904523536
TAU is 6.28318530717958647692

extern *sqrt(x: f64) -> f64

# Intrinsic wrappers
*ln(x)
    __ln(x)

*log2(x)
    __log2(x)

*log10(x)
    __log10(x)

*exp(x)
    __exp(x)

*exp2(x)
    __exp2(x)

*powf(x, y)
    __powf(x, y)

*copysign(x, y)
    __copysign(x, y)

*fma(a, b, c)
    __fma(a, b, c)

# Composite functions
*log_base(x, base)
    __ln(x) / __ln(base)

*degrees(radians)
    radians * 180.0 / PI

*radians(deg)
    deg * PI / 180.0

*hypot(x, y)
    sqrt(x * x + y * y)

*lerp(a, b, t)
    a + (b - a) * t

*map_range(value, in_min, in_max, out_min, out_max)
    (value - in_min) / (in_max - in_min) * (out_max - out_min) + out_min

*factorial(n)
    if n <= 1
        return 1
    n * factorial(n - 1)

*gcd(a, b)
    if b equals 0
        return a
    gcd(b, a % b)

*lcm(a, b)
    (a / gcd(a, b)) * b
