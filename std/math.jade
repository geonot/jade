# std.math — Mathematics
# Constants and functions built on LLVM intrinsic builtins

PI is 3.14159265358979323846
E is 2.71828182845904523536
TAU is 6.28318530717958647692

# Intrinsic wrappers
*ln(x: f64)
    __ln(x)

*log2(x: f64)
    __log2(x)

*log10(x: f64)
    __log10(x)

*exp(x: f64)
    __exp(x)

*exp2(x: f64)
    __exp2(x)

*powf(x: f64, y: f64)
    __powf(x, y)

*copysign(x: f64, y: f64)
    __copysign(x, y)

*fma(a: f64, b: f64, c: f64)
    __fma(a, b, c)

# Composite functions
*log_base(x: f64, base: f64)
    __ln(x) / __ln(base)

*degrees(radians: f64)
    radians * 180.0 / PI

*radians(deg: f64)
    deg * PI / 180.0

*hypot(x: f64, y: f64)
    sqrt(x * x + y * y)

*lerp(a: f64, b: f64, t: f64)
    a + (b - a) * t

*map_range(value: f64, in_min: f64, in_max: f64, out_min: f64, out_max: f64)
    (value - in_min) / (in_max - in_min) * (out_max - out_min) + out_min

*factorial(n)
    if n <= 1
        return 1
    n * factorial(n - 1)

*gcd(a, b)
    if b equals 0
        return a
    gcd(b, a % b)

*lcm(a, b)
    (a / gcd(a, b)) * b
