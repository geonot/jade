# std.convert — String/number type conversions
#
# Robust parsers and formatters that complement the language built-ins.
#
# Usage:
#   convert.parse_int("42")           # 42
#   convert.parse_int_radix("ff", 16) # 255
#   convert.parse_float("3.14")       # 3.14
#   convert.parse_bool("true")        # true
#   convert.format_int(42, 16)        # "2a"
#   convert.try_parse_int("xyz")      # ParseResult{ok:false, value:0}

extern *atof(s as %i8) returns f64

DIGITS_LOWER is "0123456789abcdefghijklmnopqrstuvwxyz"
DIGITS_UPPER is "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"

# Result of a fallible parse.
type ParseResult
    ok as bool
    value as i64

type ParseFloatResult
    ok as bool
    value as f64

# ── Floats ───────────────────────────────────────────────────

# Parse a string into f64. Returns 0.0 on invalid input (silent).
*parse_float(s as String) returns f64
    extern.atof(%s)

# Parse with success indicator.
*try_parse_float(s as String) returns ParseFloatResult
    if s.length equals 0
        return ParseFloatResult(ok is false, value is 0.0)
    i is 0
    if s.char_at(0) equals 45 or s.char_at(0) equals 43
        i is 1
    saw_digit is false
    while i < s.length
        c is s.char_at(i)
        if c >= 48 and c <= 57
            saw_digit is true
        elif c equals 46 or c equals 101 or c equals 69
            # OK
        elif c equals 45 or c equals 43
            # OK in exponent
        else
            return ParseFloatResult(ok is false, value is 0.0)
        i is i + 1
    if not saw_digit
        return ParseFloatResult(ok is false, value is 0.0)
    ParseFloatResult(ok is true, value is extern.atof(%s))

# ── Integers ─────────────────────────────────────────────────

# Parse base-10 integer (silent: 0 on failure).
*parse_int(s as String) returns i64
    parse_int_radix(s, 10)

# Parse with explicit base (2..36). Accepts optional 0x/0X (16),
# 0b/0B (2), 0o/0O (8) prefixes when `base` matches.
*parse_int_radix(s as String, base as i64) returns i64
    if s.length equals 0
        return 0
    neg is false
    i is 0
    c is s.char_at(0)
    if c equals 45
        neg is true
        i is 1
    elif c equals 43
        i is 1
    if i + 1 < s.length and s.char_at(i) equals 48
        nx is s.char_at(i + 1)
        if base equals 16 and (nx equals 120 or nx equals 88)
            i is i + 2
        elif base equals 2 and (nx equals 98 or nx equals 66)
            i is i + 2
        elif base equals 8 and (nx equals 111 or nx equals 79)
            i is i + 2
    n is 0
    while i < s.length
        v is __digit_value(s.char_at(i))
        if v < 0 or v >= base
            break
        n is n * base + v
        i is i + 1
    neg ? 0 - n ! n

# Strict parser; returns ok=false on any non-digit character.
*try_parse_int(s as String) returns ParseResult
    try_parse_int_radix(s, 10)

*try_parse_int_radix(s as String, base as i64) returns ParseResult
    if s.length equals 0
        return ParseResult(ok is false, value is 0)
    neg is false
    i is 0
    c is s.char_at(0)
    if c equals 45
        neg is true
        i is 1
    elif c equals 43
        i is 1
    if i >= s.length
        return ParseResult(ok is false, value is 0)
    n is 0
    while i < s.length
        v is __digit_value(s.char_at(i))
        if v < 0 or v >= base
            return ParseResult(ok is false, value is 0)
        n is n * base + v
        i is i + 1
    ParseResult(ok is true, value is neg ? 0 - n ! n)

*parse_hex(s as String) returns i64
    parse_int_radix(s, 16)

*parse_octal(s as String) returns i64
    parse_int_radix(s, 8)

*parse_binary(s as String) returns i64
    parse_int_radix(s, 2)

# ── Booleans ─────────────────────────────────────────────────

# Recognises true/false, yes/no, 1/0, on/off (case-insensitive).
*parse_bool(s as String) returns bool
    t is __ascii_lower(s)
    if t equals "true"
        return true
    if t equals "yes"
        return true
    if t equals "1"
        return true
    if t equals "on"
        return true
    false

*try_parse_bool(s as String) returns ParseResult
    t is __ascii_lower(s)
    if t equals "true" or t equals "yes" or t equals "1" or t equals "on"
        return ParseResult(ok is true, value is 1)
    if t equals "false" or t equals "no" or t equals "0" or t equals "off"
        return ParseResult(ok is true, value is 0)
    ParseResult(ok is false, value is 0)

# ── Formatting ───────────────────────────────────────────────

*format_int(n as i64, base as i64) returns String
    if n equals 0
        return "0"
    v is n < 0 ? 0 - n ! n
    out is ""
    while v > 0
        d is v mod base
        out is DIGITS_LOWER.slice(d, d + 1) + out
        v is v / base
    n < 0 ? "-" + out ! out

*format_int_upper(n as i64, base as i64) returns String
    if n equals 0
        return "0"
    v is n < 0 ? 0 - n ! n
    out is ""
    while v > 0
        d is v mod base
        out is DIGITS_UPPER.slice(d, d + 1) + out
        v is v / base
    n < 0 ? "-" + out ! out

*format_bool(b as bool) returns String
    b ? "true" ! "false"

# ── Internal ─────────────────────────────────────────────────

*__digit_value(ch as i64) returns i64
    if ch >= 48 and ch <= 57
        return ch - 48
    if ch >= 97 and ch <= 122
        return ch - 87
    if ch >= 65 and ch <= 90
        return ch - 55
    -1

*__ascii_lower(s as String) returns String
    out is ""
    i is 0
    while i < s.length
        c is s.char_at(i)
        if c >= 65 and c <= 90
            out is out + chr(c + 32)
        else
            out is out + s.slice(i, i + 1)
        i is i + 1
    out
