# std.result — Option and Result enums with helpers
#
# Usage:
#   x is Some(42)
#   if is_some(x)
#       log(unwrap(x))
#
#   res is Ok('hello')
#   if is_ok(res)
#       log(unwrap_ok(res))

enum Option
    Some(i64)
    None

enum Result
    Ok(i64)
    Err(String)

# ── Option helpers ───────────────────────────────────────────

*is_some(opt as Option)
    match opt
        Some(_) ? true
        None ? false

*is_none(opt as Option)
    match opt
        Some(_) ? false
        None ? true

*unwrap(opt as Option)
    match opt
        Some(v) ? v
        None ?
            assert(false)
            0

*unwrap_or(opt as Option, fallback)
    match opt
        Some(v) ? v
        None ? fallback

*map_opt(opt as Option, f)
    match opt
        Some(v) ? Some(f(v))
        None ? None

# ── Result helpers ───────────────────────────────────────────

*is_ok(res as Result)
    match res
        Ok(_) ? true
        Err(_) ? false

*is_err(res as Result)
    match res
        Ok(_) ? false
        Err(_) ? true

*unwrap_ok(res as Result)
    match res
        Ok(v) ? v
        Err(e) ?
            assert(false)
            0

*unwrap_err(res as Result)
    match res
        Ok(_) ?
            assert(false)
            ''
        Err(e) ? e

*ok_or(res as Result, fallback)
    match res
        Ok(v) ? v
        Err(_) ? fallback

*map_res(res as Result, f)
    match res
        Ok(v) ? Ok(f(v))
        Err(e) ? Err(e)
