# std.csv — CSV parser and writer (RFC 4180)
#
# Usage:
#   rows is csv.parse("name,age\nAlice,30\nBob,25")
#   text is csv.stringify(rows)
#
#   reader is csv.reader(text)
#   while reader.has_next()
#       row is reader.next_row()

# Parse a CSV string into a vector of rows (each row is a vector of strings).
*parse(text as String)
    rows is vec()
    if text.length equals 0
        return rows
    row is vec()
    i is 0
    in_quotes is false
    field_start is 0
    field is ""
    while i < text.length
        ch is text.char_at(i)
        if in_quotes
            if ch equals 34
                # Check for escaped quote ("")
                if i + 1 < text.length and text.char_at(i + 1) equals 34
                    field is field + '"'
                    i is i + 2
                else
                    in_quotes is false
                    i is i + 1
            else
                field is field + text.slice(i, i + 1)
                i is i + 1
        else
            if ch equals 34
                in_quotes is true
                i is i + 1
            elif ch equals 44
                row.push(field)
                field is ""
                i is i + 1
            elif ch equals 10
                row.push(field)
                field is ""
                rows.push(row)
                row is vec()
                i is i + 1
            elif ch equals 13
                # Handle \r\n
                row.push(field)
                field is ""
                rows.push(row)
                row is vec()
                i is i + 1
                if i < text.length and text.char_at(i) equals 10
                    i is i + 1
            else
                field is field + text.slice(i, i + 1)
                i is i + 1
    # Push last field and last row
    need_push is false
    if field.length > 0
        need_push is true
    if row.length > 0
        need_push is true
    if need_push
        row.push(field)
        rows.push(row)
    rows

# Convert a vector of rows back to a CSV string.
*stringify(rows)
    result is ""
    loop rows
        loop $
            if $$ > 0
                result is result + ","
            result is result + escape_field($)
        result is result + "\n"
    result

# Escape a single CSV field — quotes it if it contains comma, quote, or newline.
*escape_field(field as String) returns String
    needs_quote is false
    i is 0
    while i < field.length
        ch is field.char_at(i)
        if ch equals 44
            needs_quote is true
        elif ch equals 34
            needs_quote is true
        elif ch equals 10
            needs_quote is true
        elif ch equals 13
            needs_quote is true
        if needs_quote
            break
        i is i + 1
    if needs_quote is false
        return field
    result is '"'
    i is 0
    while i < field.length
        ch is field.char_at(i)
        if ch equals 34
            result is result + '""'
        else
            result is result + field.slice(i, i + 1)
        i is i + 1
    result + '"'

# Get a specific column by header name from parsed CSV.
# First row is treated as headers.
*get_column(rows, header as String)
    if rows.length < 1
        return vec()
    headers is rows.get(0)
    col_idx is -1
    loop headers
        if $ equals header
            col_idx is $$
            break
    if col_idx < 0
        return vec()
    result is vec()
    loop rows
        if $$ > 0
            if col_idx < $.length
                result.push($.get(col_idx))
            else
                result.push("")
    result

# Convert parsed CSV rows to a vector of maps (header -> value).
# First row is treated as headers.
*to_records(rows)
    if rows.length < 2
        return vec()
    headers is rows.get(0)
    records is vec()
    loop rows
        if $$ > 0
            row is $
            record is map()
            loop headers
                if $$ < row.length
                    record.set($, row.get($$))
                else
                    record.set($, "")
            records.push(record)
    records

# ── Streaming Reader ─────────────────────────────────────────

type Reader
    text as String
    pos as i64
    done as bool

    *has_next returns bool
        if self.done
            return false
        self.pos < self.text.length

    *next_row
        if self.pos >= self.text.length
            self.done is true
            return vec()
        row is vec()
        field is ""
        in_quotes is false
        while self.pos < self.text.length
            ch is self.text.char_at(self.pos)
            if in_quotes
                if ch equals 34
                    if self.pos + 1 < self.text.length and self.text.char_at(self.pos + 1) equals 34
                        field is field + '"'
                        self.pos is self.pos + 2
                    else
                        in_quotes is false
                        self.pos is self.pos + 1
                else
                    field is field + self.text.slice(self.pos, self.pos + 1)
                    self.pos is self.pos + 1
            else
                if ch equals 34
                    in_quotes is true
                    self.pos is self.pos + 1
                elif ch equals 44
                    row.push(field)
                    field is ""
                    self.pos is self.pos + 1
                elif ch equals 10
                    self.pos is self.pos + 1
                    row.push(field)
                    return row
                elif ch equals 13
                    self.pos is self.pos + 1
                    if self.pos < self.text.length and self.text.char_at(self.pos) equals 10
                        self.pos is self.pos + 1
                    row.push(field)
                    return row
                else
                    field is field + self.text.slice(self.pos, self.pos + 1)
                    self.pos is self.pos + 1
        has_data is false
        if field.length > 0
            has_data is true
        if row.length > 0
            has_data is true
        if has_data
            row.push(field)
        self.done is true
        row

*reader(text as String) returns Reader
    Reader(text is text, pos is 0, done is false)
