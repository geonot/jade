# std.tls — TLS/SSL encrypted connections
#
# Usage:
#   conn is tls.connect("example.com", 443)
#   conn.write("GET / HTTP/1.1\r\nHost: example.com\r\n\r\n")
#   data is conn.read(8192)
#   conn.shut()

extern *jade_tls_connect(host as %i8, port as i32) returns %i8
extern *jade_tls_send(conn as %i8, buf as %i8, len as i64) returns i64
extern *jade_tls_recv(conn as %i8, buf as %i8, len as i64) returns i64
extern *jade_tls_close(conn as %i8)
extern *malloc(size as i64) returns %i8
extern *free(ptr as %i8)

type TlsStream
    handle as %i8

    *read(max_bytes as i64) returns String
        buf is extern.malloc(max_bytes + 1)
        n is extern.jade_tls_recv(self.handle, buf, max_bytes)
        if n <= 0
            extern.free(buf)
            return ""
        __string_from_raw(buf, n, max_bytes + 1)

    *read_all returns String
        result is ""
        loop
            chunk is self.read(8192)
            if chunk.length equals 0
                break
            result is result + chunk
        result

    *write(data as String)
        extern.jade_tls_send(self.handle, %data, data.length)

    *write_all(data as String)
        sent is 0
        while sent < data.length
            remaining is data.slice(sent, data.length)
            n is extern.jade_tls_send(self.handle, %remaining, remaining.length)
            if n <= 0
                return false
            sent is sent + n
        true

    *shut
        extern.jade_tls_close(self.handle)

# Create a TLS connection to a host and port.
# Returns a TlsStream on success.
*connect(host as String, port as i64) returns TlsStream
    handle is extern.jade_tls_connect(%host, port as i32)
    TlsStream(handle is handle)

# Check if a TLS stream is valid (connected).
*is_valid(stream as TlsStream) returns bool
    stream.handle as i64 neq 0
