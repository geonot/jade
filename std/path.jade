# std.path — Path manipulation

*path_join(a: String, b: String) -> String
    if a.length equals 0
        return b
    if b.length equals 0
        return a
    last is a.char_at(a.length - 1)
    if last equals 47
        a + b
    else
        a + "/" + b

*path_dir(path: String) -> String
    i is path.length - 1
    while i >= 0
        if path.char_at(i) equals 47
            return path.slice(0, i)
        i is i - 1
    "."

*path_base(path: String) -> String
    i is path.length - 1
    while i >= 0
        if path.char_at(i) equals 47
            return path.slice(i + 1, path.length)
        i is i - 1
    path

*path_ext(path: String) -> String
    base is path_base(path)
    i is base.length - 1
    while i >= 0
        if base.char_at(i) equals 46
            return base.slice(i, base.length)
        i is i - 1
    ""
