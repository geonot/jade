# std.crypto — Cryptographic primitives index
#
# This module provides the cross-cutting primitives that don't belong to a
# single algorithm family:
#
#   * `random_bytes` / `random_hex`    — CSPRNG (OpenSSL `RAND_bytes`)
#   * `hmac` / `hmac_sha256` / etc.    — HMAC (RFC 2104) over any digest
#   * `chacha20_poly1305_*`            — RFC 8439 AEAD
#   * `pbkdf2`                         — RFC 8018 PBKDF2-HMAC
#   * `scrypt`                         — RFC 7914
#   * `secure_compare`                 — constant-time byte comparison
#
# Single-algorithm families live in dedicated modules:
#
#   * `std.sha`     — SHA-1, SHA-2, SHA-3 hashing
#   * `std.blake`   — BLAKE2 / BLAKE3 hashing
#   * `std.aes`     — AES-256 (GCM, CBC)
#   * `std.argon`   — Argon2id password hashing / KDF
#
# All inputs/outputs are raw byte strings unless suffixed with `_hex`.
# Standards: RFC 2104, RFC 7914, RFC 8018, RFC 8439, RFC 9106.

extern *jade_random_bytes(buf as %i8, n as i64) returns i32
extern *jade_evp_hmac(alg as %i8, key as %i8, key_len as i64, data as %i8, data_len as i64, out as %i8) returns i64
extern *jade_hmac_sha256(key as %i8, key_len as i64, data as %i8, data_len as i64, out as %i8) returns i32
extern *jade_pbkdf2(alg as %i8, pass as %i8, pass_len as i64, salt as %i8, salt_len as i64, iters as i64, dklen as i64, out as %i8) returns i32
extern *jade_scrypt(pass as %i8, pass_len as i64, salt as %i8, salt_len as i64, n as i64, r as i64, p as i64, dklen as i64, out as %i8) returns i32
extern *jade_chacha20_poly1305_encrypt(key as %i8, nonce as %i8, pt as %i8, pt_len as i64, aad as %i8, aad_len as i64, out as %i8, tag as %i8) returns i64
extern *jade_chacha20_poly1305_decrypt(key as %i8, nonce as %i8, ct as %i8, ct_len as i64, aad as %i8, aad_len as i64, tag as %i8, out as %i8) returns i64
extern *jade_bytes_to_hex(data as %i8, len as i64, out as %i8)
extern *jade_hex_to_bytes(hex as %i8, hex_len as i64, out as %i8) returns i64
extern *malloc(size as i64) returns %i8
extern *free(ptr as %i8)

# ── Random ───────────────────────────────────────────────────

*random_bytes(n as i64) returns String
    if n <= 0
        return ""
    buf is extern.malloc(n)
    rc is extern.jade_random_bytes(buf, n)
    if rc neq 0
        extern.free(buf)
        return ""
    result is __string_from_ptr_len(buf, n)
    extern.free(buf)
    result

*random_hex(n as i64) returns String
    if n <= 0
        return ""
    buf is extern.malloc(n)
    hex_buf is extern.malloc(n * 2 + 1)
    rc is extern.jade_random_bytes(buf, n)
    if rc neq 0
        extern.free(buf)
        extern.free(hex_buf)
        return ""
    extern.jade_bytes_to_hex(buf, n, hex_buf)
    result is __string_from_ptr(hex_buf)
    extern.free(buf)
    extern.free(hex_buf)
    result

*random_key returns String
    random_bytes(32)

*random_nonce returns String
    random_bytes(12)

*random_token returns String
    random_hex(32)

# ── HMAC (RFC 2104) ──────────────────────────────────────────

*hmac(alg as String, key as String, data as String) returns String
    out is extern.malloc(64)
    n is extern.jade_evp_hmac(%alg, %key, key.length, %data, data.length, out)
    if n < 0
        extern.free(out)
        return ""
    result is __string_from_ptr_len(out, n)
    extern.free(out)
    result

*hmac_hex(alg as String, key as String, data as String) returns String
    raw is hmac(alg, key, data)
    if raw.length equals 0
        return ""
    __bytes_to_hex(raw)

*hmac_sha256(key as String, data as String) returns String
    out_buf is extern.malloc(32)
    hex_buf is extern.malloc(65)
    rc is extern.jade_hmac_sha256(%key, key.length, %data, data.length, out_buf)
    if rc neq 0
        extern.free(out_buf)
        extern.free(hex_buf)
        return ""
    extern.jade_bytes_to_hex(out_buf, 32, hex_buf)
    result is __string_from_ptr(hex_buf)
    extern.free(out_buf)
    extern.free(hex_buf)
    result

*hmac_sha512(key as String, data as String) returns String
    hmac_hex("SHA512", key, data)

# ── ChaCha20-Poly1305 AEAD (RFC 8439) ───────────────────────

type AeadResult
    ciphertext as String
    tag as String
    ok as bool

*chacha20_poly1305_encrypt(key as String, nonce as String, plaintext as String, aad as String) returns AeadResult
    if key.length neq 32 or nonce.length neq 12
        return AeadResult(ciphertext is "", tag is "", ok is false)
    ct_buf is extern.malloc(plaintext.length + 16)
    tag_buf is extern.malloc(16)
    n is extern.jade_chacha20_poly1305_encrypt(%key, %nonce, %plaintext, plaintext.length, %aad, aad.length, ct_buf, tag_buf)
    if n < 0
        extern.free(ct_buf)
        extern.free(tag_buf)
        return AeadResult(ciphertext is "", tag is "", ok is false)
    ct is __string_from_ptr_len(ct_buf, n)
    tag is __string_from_ptr_len(tag_buf, 16)
    extern.free(ct_buf)
    extern.free(tag_buf)
    AeadResult(ciphertext is ct, tag is tag, ok is true)

*chacha20_poly1305_decrypt(key as String, nonce as String, ciphertext as String, aad as String, tag as String) returns String
    if key.length neq 32 or nonce.length neq 12 or tag.length neq 16
        return ""
    pt_buf is extern.malloc(ciphertext.length + 1)
    n is extern.jade_chacha20_poly1305_decrypt(%key, %nonce, %ciphertext, ciphertext.length, %aad, aad.length, %tag, pt_buf)
    if n < 0
        extern.free(pt_buf)
        return ""
    result is __string_from_ptr_len(pt_buf, n)
    extern.free(pt_buf)
    result

# ── PBKDF2 (RFC 8018) ───────────────────────────────────────

*pbkdf2(alg as String, password as String, salt as String, iters as i64, dklen as i64) returns String
    if dklen <= 0 or iters < 1
        return ""
    out is extern.malloc(dklen)
    rc is extern.jade_pbkdf2(%alg, %password, password.length, %salt, salt.length, iters, dklen, out)
    if rc neq 0
        extern.free(out)
        return ""
    result is __string_from_ptr_len(out, dklen)
    extern.free(out)
    result

*pbkdf2_sha256(password as String, salt as String, iters as i64, dklen as i64) returns String
    pbkdf2("SHA256", password, salt, iters, dklen)

*pbkdf2_sha512(password as String, salt as String, iters as i64, dklen as i64) returns String
    pbkdf2("SHA512", password, salt, iters, dklen)

# ── scrypt (RFC 7914) ───────────────────────────────────────

*scrypt(password as String, salt as String, n as i64, r as i64, p as i64, dklen as i64) returns String
    if dklen <= 0
        return ""
    out is extern.malloc(dklen)
    rc is extern.jade_scrypt(%password, password.length, %salt, salt.length, n, r, p, dklen, out)
    if rc neq 0
        extern.free(out)
        return ""
    result is __string_from_ptr_len(out, dklen)
    extern.free(out)
    result

*scrypt_default(password as String, salt as String, dklen as i64) returns String
    scrypt(password, salt, 16384, 8, 1, dklen)

# ── Constant-time comparison ────────────────────────────────

*secure_compare(a as String, b as String) returns bool
    if a.length neq b.length
        return false
    diff is 0
    i is 0
    while i < a.length
        diff is diff | (a.char_at(i) ^ b.char_at(i))
        i is i + 1
    diff equals 0

# ── Hex helpers (re-exported for convenience) ───────────────

*to_hex(data as String) returns String
    __bytes_to_hex(data)

*from_hex(hex as String) returns String
    __hex_to_bytes(hex)

*__bytes_to_hex(data as String) returns String
    if data.length equals 0
        return ""
    hex_buf is extern.malloc(data.length * 2 + 1)
    extern.jade_bytes_to_hex(%data, data.length, hex_buf)
    result is __string_from_ptr(hex_buf)
    extern.free(hex_buf)
    result

*__hex_to_bytes(hex as String) returns String
    if hex.length equals 0 or hex.length mod 2 neq 0
        return ""
    n is hex.length / 2
    buf is extern.malloc(n)
    rc is extern.jade_hex_to_bytes(%hex, hex.length, buf)
    if rc < 0
        extern.free(buf)
        return ""
    result is __string_from_ptr_len(buf, n)
    extern.free(buf)
    result
