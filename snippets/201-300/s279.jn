# Bank A/B failover: choose newer non-corrupt bank.
*choose_bank(ver_a as i64, ok_a as i64, ver_b as i64, ok_b as i64) returns i64
    if ok_a equals 1 and (ok_b equals 0 or ver_a >= ver_b)
        return 0
    if ok_b equals 1
        return 1
    -1

*main
    log choose_bank(7, 1, 8, 1)
    log choose_bank(7, 0, 8, 1)
    log choose_bank(7, 0, 8, 0)
