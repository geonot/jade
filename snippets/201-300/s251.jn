# Apply 2x2 rotation matrix to a vector.
*rotx(a as i64, b as i64, c as i64, d as i64, x as i64, y as i64) returns i64
    a * x + b * y

*roty(a as i64, b as i64, c as i64, d as i64, x as i64, y as i64) returns i64
    c * x + d * y

*main
    log rotx(0, -1, 1, 0, 100, 50)
    log roty(0, -1, 1, 0, 100, 50)
