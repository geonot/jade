# HFT: limit order book match step (single price level).
*match_qty(book_bid as i64, book_ask as i64, incoming as i64, side as i64) returns i64
    if side equals 1
        if incoming <= book_ask
            return incoming
        book_ask
    else
        if incoming <= book_bid
            return incoming
        book_bid

*main
    log match_qty(100, 80, 50, 1)
    log match_qty(100, 80, 200, 1)
    log match_qty(100, 80, 150, 0)
