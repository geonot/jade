# 4-bit ripple-carry adder.
*radd(a as i64, b as i64) returns i64
    carry is 0
    sum is 0
    bit is 0
    while bit < 4
        ab is (a / (1 << bit)) % 2
        bb is (b / (1 << bit)) % 2
        s is ab + bb + carry
        sum is sum + (s % 2) * (1 << bit)
        carry is s / 2
        bit is bit + 1
    sum + carry * 16

*main
    log radd(7, 5)
    log radd(15, 1)
