# Priority queue (min) via linear scan + swap-pop.
*main
    h is vec()
    h.push(7)
    h.push(2)
    h.push(9)
    h.push(4)
    h.push(1)
    h.push(6)
    while h.length > 0
        # find min idx
        mi is 0
        i is 1
        while i < h.length
            if h.get(i) < h.get(mi)
                mi is i
            i is i + 1
        log h.get(mi)
        last is h.length - 1
        h.set(mi, h.get(last))
        h.pop()
