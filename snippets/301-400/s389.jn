# Strictly monotonic increasing check.
*is_strict_inc(a as Vec of i64) returns bool
    i is 1
    while i < a.length
        if a.get(i) <= a.get(i - 1)
            return false
        i is i + 1
    true

*main
    a is vec()
    a.push(1)
    a.push(2)
    a.push(3)
    log is_strict_inc(a)
    b is vec()
    b.push(1)
    b.push(1)
    b.push(2)
    log is_strict_inc(b)
