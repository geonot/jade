# Reverse a Vec by walking from the back and pushing.
*reverse(xs as Vec of i64) returns Vec of i64
    out is vec()
    i is xs.length - 1
    while i >= 0
        out.push(xs.get(i))
        i is i - 1
    out

*main
    xs is vec()
    i is 1
    while i <= 5
        xs.push(i)
        i is i + 1
    r is reverse(xs)
    log r.get(0)
    log r.get(4)
