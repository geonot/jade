# Multiset count: count occurrences of each value (0..9) in a vec.
*main
    xs is vec()
    xs.push(0)
    xs.push(3)
    xs.push(7)
    xs.push(3)
    xs.push(7)
    xs.push(7)
    xs.push(0)
    cnt is vec()
    i is 0
    while i < 10
        cnt.push(0)
        i is i + 1
    j is 0
    while j < xs.length
        v is xs.get(j)
        cnt.set(v, cnt.get(v) + 1)
        j is j + 1
    k is 0
    while k < 10
        if cnt.get(k) > 0
            log '{k}: {cnt.get(k)}'
        k is k + 1
