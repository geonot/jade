# filter: keep only elements satisfying predicate.
*filter_i64(xs as Vec of i64, p as (i64) returns bool) returns Vec of i64
    out is vec()
    i is 0
    while i < xs.length
        v is xs.get(i)
        if p(v)
            out.push(v)
        i is i + 1
    out

*main
    xs is vec()
    i is 1
    while i <= 10
        xs.push(i)
        i is i + 1
    evens is filter_i64(xs, |n as i64| n mod 2 equals 0)
    log evens.length
    log evens.get(0)
    log evens.get(4)
