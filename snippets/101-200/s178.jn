# Fizzbuzz 1..15 (no chained-and, no chained-or).
*main
    i is 1
    while i <= 15
        if i mod 15 equals 0
            log "fizzbuzz"
        else
            if i mod 3 equals 0
                log "fizz"
            else
                if i mod 5 equals 0
                    log "buzz"
                else
                    log i
        i is i + 1
