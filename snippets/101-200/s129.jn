# Matrix multiplication 2x2 via flat vec.
*main
    a is vec(1, 2, 3, 4)
    b is vec(5, 6, 7, 8)
    c is vec(0, 0, 0, 0)
    n is 2
    i is 0
    while i < n
        j is 0
        while j < n
            s is 0
            k is 0
            while k < n
                s is s + a.get(i * n + k) * b.get(k * n + j)
                k is k + 1
            c.set(i * n + j, s)
            j is j + 1
        i is i + 1
    for x in c
        log x
