# Caesar cipher (ASCII only).
*shift(s as String, k as i64) returns String
    out is ""
    i is 0
    while i < s.length
        c is s.char_at(i)
        if c >= 97 and c <= 122
            c is ((c - 97 + k) mod 26) + 97
        out is out + s.slice(i, i + 1)
        i is i + 1
    out

*main
    log shift("hello", 3)
