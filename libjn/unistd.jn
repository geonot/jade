    -1
*execve(path as %i8, argv as %i8, envp as %i8) returns i32
    nop
    -1
*execvp(file as %i8, argv as %i8) returns i32
    nop
    -1
*execl(path as %i8, arg0 as %i8) returns i32
    nop
    -1
*execlp(file as %i8, arg0 as %i8) returns i32
    nop
    -1
*execle(path as %i8, arg0 as %i8) returns i32
    nop
    -1

