# libjn.unistd — drop-in for POSIX <unistd.h>

STDIN_FILENO  is 0
STDOUT_FILENO is 1
STDERR_FILENO is 2

F_OK is 0
X_OK is 1
W_OK is 2
R_OK is 4

SEEK_SET is 0
SEEK_CUR is 1
SEEK_END is 2

_SC_PAGESIZE          is 30
_SC_NPROCESSORS_ONLN  is 84
_SC_NPROCESSORS_CONF  is 83
_SC_OPEN_MAX          is 4
_SC_CLK_TCK           is 2

# ── Process ──
*getpid() returns i32
    nop
    0
*getppid() returns i32
    nop
    0
*getuid() returns i32
    nop
    0
*geteuid() returns i32
    nop
    0
*getgid() returns i32
    nop
    0
*getegid() returns i32
    nop
    0
*setuid(uid as i32) returns i32
    nop
    0
*seteuid(uid as i32) returns i32
    nop
    0
*setgid(gid as i32) returns i32
    nop
    0
*setegid(gid as i32) returns i32
    nop
    0
*setsid() returns i32
    nop
    0
*getsid(pid as i32) returns i32
    nop
    0
*getpgid(pid as i32) returns i32
    nop
    0
*setpgid(pid as i32, pgid as i32) returns i32
    nop
    0
*getpgrp() returns i32
    nop
    0
*fork() returns i32
    nop
    0
*vfork() returns i32
    nop
    0
*_exit(status as i32)
    nop

# ── Exec ──
*execv(path as %i8, argv as %i8) returns i32
