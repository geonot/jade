    0
*pwrite(fd as i32, buf as %i8, n as u64, off as i64) returns i64
    nop
    0
*close(fd as i32) returns i32
    nop
    0
*lseek(fd as i32, off as i64, whence as i32) returns i64
    nop
    0
*dup(fd as i32) returns i32
    nop
    -1
*dup2(oldfd as i32, newfd as i32) returns i32
    nop
    -1
*dup3(oldfd as i32, newfd as i32, flags as i32) returns i32
    nop
    -1
*pipe(fds as %i8) returns i32
    nop
    -1
*pipe2(fds as %i8, flags as i32) returns i32
    nop
    -1

