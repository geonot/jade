type Item
    sku as i64
    qty as i64
    warehouse as i64

*new(sku as i64, qty as i64, warehouse as i64) returns Item
    Item(sku is sku, qty is qty, warehouse is warehouse)

*adjust(it as Item, delta as i64) returns Item
    Item(sku is it.sku, qty is it.qty + delta, warehouse is it.warehouse)
