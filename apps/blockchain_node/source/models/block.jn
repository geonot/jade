use models/tx

type Block
    height as i64
    prev_hash as i64
    merkle as i64
    nonce as i64
    hash as i64
    tx_count as i64

*new(height as i64, prev_hash as i64, merkle as i64, nonce as i64, hash as i64, tx_count as i64) returns Block
    Block(height is height, prev_hash is prev_hash, merkle is merkle, nonce is nonce, hash is hash, tx_count is tx_count)
