use std/time
use models/message
use models/user
use moderation
use room

extern *usleep(us as i32) returns i32

*main
    r is spawn Room
    loop(0, $ < 200, $ + 1)
        r.post(message.new($ % 5, $, $))
    extern.usleep(120000)
    r.snapshot()
    extern.usleep(40000)
    stop r
    extern.usleep(20000)
    log 'sent'
    log 200
